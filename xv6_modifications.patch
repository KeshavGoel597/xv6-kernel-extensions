+uint64
+sys_proc_stats(void)
+{
+#ifdef CFS
+    uint total_wait = 0;
+    uint total_run = 0;
+    int num_procs = 0;
+    struct proc *p;
+
+    printf("\n--- CFS Process Stats ---\n");
+
+    // Iterate through all processes to find finished children of the test
+    for (p = proc; p < &proc[NPROC]; p++) {
+        // We look for ZOMBIE states as they have exited but not been cleaned up yet.
+        // PIDs > 2 are used to skip init and the shell.
+        if (p->pid > 2 && p->creation_time > 0) { 
+            if(p->state == ZOMBIE || p->state == UNUSED) {
+                uint turnaround_time = ticks - p->creation_time;
+                uint wait_time = turnaround_time - p->run_ticks - p->sleep_ticks;
+
+                total_wait += wait_time;
+                total_run += p->run_ticks;
+                num_procs++;
+            }
+        }
+    }
+
+    if (num_procs > 0) {
+        printf("Total test processes finished: %d\n", num_procs);
+        printf("Average Waiting Time: %d ticks\n", total_wait / num_procs);
+        printf("Average Running Time: %d ticks\n", total_run / num_procs);
+    } else {
+        printf("No completed test processes to calculate stats.\n");
+    }
+    printf("---------------------\n");
+#else
+    // If not using CFS, print a message indicating stats are not supported.
+    printf("\nProcess statistics are only available for the CFS scheduler.\n");
+#endif
+    return 0;
+}
